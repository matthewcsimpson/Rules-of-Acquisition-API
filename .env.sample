
# App HTTP port (Express listens here; defaults to 5555).
PORT="<port>"

# Preferred: a single Postgres connection string. Heroku Postgres sets this
# automatically; locally you can copy it from `heroku config:get DATABASE_URL`.
DATABASE_URL="postgres://user:password@host:5432/databasename"

# Fallback for local development when DATABASE_URL is not set:
DATABASE_HOST="<hostname>"
DATABASE_PORT="5432"
DATABASE_USER="<username>"
DATABASE_PASSWORD="<password>"
DATABASE_NAME="<databasename>"
